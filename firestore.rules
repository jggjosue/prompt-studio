/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. All user-generated
 * data (profiles, content, collections) is stored in subcollections under a path
 * specific to that user's ID (`/users/{userId}`). This ensures that users can only
 * access and manage their own data.
 *
 * Data Structure: The data is organized into two main categories:
 * 1. User-Private Data: Nested under `/users/{userId}`, this includes collections for
 *    `generatedContent`, `collections`, and `placeholderVideos` and `placeholderImages`. Access is strictly limited
 *    to the authenticated owner of the parent user document.
 * 2. Public Data: Collections like `/aiModels`, `/promptExamples`, and `placeholderVideos` and `placeholderImages`
 *    contain application-wide data that is readable by anyone but has restricted write access.
 *
 * Key Security Decisions:
 * - User Enumeration is disallowed by preventing `list` operations on the top-level `/users` collection.
 * - All write operations (create, update, delete) require user authentication unless specified.
 * - Public data collections (`aiModels`, `promptExamples`) are strictly read-only from the client-side
 *   to prevent unauthorized modification.
 * - Like counts can be updated atomically by any authenticated user.
 * - A user's own likes are private and can only be managed by them.
 *
 * Denormalization for Authorization: The entire structure is built on this principle. By placing
 * all of a user's data within their own document tree (e.g., `/users/{userId}/...`), we avoid
 * complex and slow `get()` calls. Authorization checks are fast and simple, based directly on
 * the `userId` wildcard in the path.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------

    /**
     * Checks if a user is authenticated.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * Checks if the authenticated user's UID matches the provided userId.
     * This is the primary function for establishing document ownership.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * Checks for ownership on an existing document. Used for safe updates and deletes.
     * Prevents operations on documents that do not exist.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --------------------------------
    // User Data Rules
    // --------------------------------

    /**
     * @description Controls access to user profile documents.
     * @path /users/{userId}
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Disallow listing all users for security.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to a user's generated content.
     * @path /users/{userId}/generatedContent/{generatedContentId}
     */
    match /users/{userId}/generatedContent/{generatedContentId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to a user's personal collections of content.
     * @path /users/{userId}/collections/{collectionId}
     */
    match /users/{userId}/collections/{collectionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Controls access to the list of available AI models.
     * @path /aiModels/{aiModelId}
     */
    match /aiModels/{aiModelId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Controls access to example prompts for users.
     * @path /promptExamples/{promptExampleId}
     */
    match /promptExamples/{promptExampleId} {
      allow get, list: if true;
      allow write: if false;
    }

    /**
     * @description Stores placeholder image titles, seeded from a script.
     * @path /placeholderImages/{imageId}
     *
     * Read: Public access
     * Create: Allowed only during seeding (via server)
     * Update: Authenticated users can only update metadata.likes atomically
     */
    match /placeholderImages/{imageId} {
      allow read: if true;
      allow create: if true; // Server-side seeding
      allow update: if isSignedIn() && onlyLikesChanged();
    }

    /**
     * @description Stores placeholder video titles, seeded from a script.
     * @path /placeholderVideos/{videoId}
     *
     * Read: Public access
     * Create: Allowed only during seeding (via server)
     * Update: Authenticated users can only update metadata.likes atomically
     */
    match /placeholderVideos/{videoId} {
      allow read: if true;
      allow create: if true; // Server-side seeding
      allow update: if isSignedIn() && onlyLikesChanged();
    }

    /**
     * @description Controls access to image prompts.
     * @path /image-prompts/{promptId}
     * 
     * Allow authenticated users to update metadata.likes atomically.
     */
    match /image-prompts/{promptId} {
      allow read: if true;
      allow create: if false; // Read-only for clients
      allow update: if isSignedIn() && onlyLikesChanged();
    }

    /**
     * @description Controls access to video prompts.
     * @path /video-prompts/{promptId}
     * 
     * Allow authenticated users to update metadata.likes atomically.
     */
    match /video-prompts/{promptId} {
      allow read: if true;
      allow create: if false; // Read-only for clients
      allow update: if isSignedIn() && onlyLikesChanged();
    }

    /**
     * @description Controls access to image tags.
     * @path /image-tags/{tagId}
     * 
     * Allow authenticated users to update metadata.likes atomically.
     */
    match /image-tags/{tagId} {
      allow read: if true;
      allow create: if false; // Read-only for clients
      allow update: if isSignedIn() && onlyLikesChanged();
    }

    /**
     * @description Controls access to video tags.
     * @path /video-tags/{tagId}
     * 
     * Allow authenticated users to update metadata.likes atomically.
     */
    match /video-tags/{tagId} {
      allow read: if true;
      allow create: if false; // Read-only for clients
      allow update: if isSignedIn() && onlyLikesChanged();
    }
  }

  /**
   * Helper function to validate that only metadata.likes is being updated.
   * Ensures atomic increments/decrements by checking that only the likes field changes.
   * Handles both new document creation and updates.
   */
  function onlyLikesChanged() {
    // For new documents (resource doesn't exist), allow initial creation
    if (resource == null) {
      return true; // Allow creation; server will set metadata.likes: 1
    }
    
    // For existing documents, validate that only metadata.likes changed
    let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
    return changedKeys.hasOnly(['metadata']) 
           && request.resource.data.metadata.diff(resource.data.metadata).affectedKeys().hasOnly(['likes'])
           && (request.resource.data.metadata.likes == resource.data.metadata.likes + 1 ||
               request.resource.data.metadata.likes == resource.data.metadata.likes - 1);
  }
